{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://slidev-agent.local/schemas/deck-spec.schema.json",
  "title": "Slidev Agent Deck Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "metadata",
    "slides"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#?[0-9A-Fa-f]{6}$"
    },
    "assetPath": {
      "type": "string",
      "minLength": 1
    },
    "fonts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "body",
        "mono"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "mono": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "background",
        "text",
        "primary",
        "accent",
        "surface",
        "muted"
      ],
      "properties": {
        "background": {
          "$ref": "#/$defs/hexColor"
        },
        "text": {
          "$ref": "#/$defs/hexColor"
        },
        "primary": {
          "$ref": "#/$defs/hexColor"
        },
        "accent": {
          "$ref": "#/$defs/hexColor"
        },
        "surface": {
          "$ref": "#/$defs/hexColor"
        },
        "muted": {
          "$ref": "#/$defs/hexColor"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "slug",
        "theme",
        "aspectRatio",
        "fonts",
        "colors"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "theme": {
          "type": "string",
          "minLength": 1
        },
        "aspectRatio": {
          "type": "string",
          "enum": [
            "16:9",
            "4:3"
          ]
        },
        "fonts": {
          "$ref": "#/$defs/fonts"
        },
        "colors": {
          "$ref": "#/$defs/colors"
        }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/assetPath"
        },
        "placement": {
          "type": "string",
          "enum": [
            "full",
            "background",
            "left",
            "right",
            "center",
            "top",
            "bottom"
          ]
        },
        "fit": {
          "type": "string",
          "enum": [
            "cover",
            "contain"
          ]
        },
        "opacity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "caption": {
          "type": "string"
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/assetPath"
        },
        "color": {
          "$ref": "#/$defs/hexColor"
        }
      },
      "anyOf": [
        {
          "required": [
            "path"
          ]
        },
        {
          "required": [
            "color"
          ]
        }
      ]
    },
    "noteLines": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "label"
      ],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "callout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        }
      }
    },
    "tableCell": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ]
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headers",
        "rows"
      ],
      "properties": {
        "headers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/tableCell"
            }
          }
        }
      }
    },
    "comparisonColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "items"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "columns"
      ],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/comparisonColumn"
          }
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "values"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "labels",
        "series"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "bar",
            "line",
            "pie",
            "doughnut"
          ]
        },
        "title": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/chartSeries"
          }
        }
      }
    },
    "processStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/processStep"
          }
        }
      }
    },
    "diagramNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string"
        }
      }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "imagePath": {
          "$ref": "#/$defs/assetPath"
        },
        "nodes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/diagramNode"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "imagePath"
          ]
        },
        {
          "required": [
            "nodes"
          ]
        }
      ]
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "kind",
        "title"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "cover",
            "section",
            "content",
            "stats",
            "comparison",
            "diagram",
            "image",
            "closing"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "layout": {
          "type": "string"
        },
        "className": {
          "type": "string"
        },
        "speakerNotes": {
          "$ref": "#/$defs/noteLines"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "body": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "background": {
          "$ref": "#/$defs/background"
        },
        "visual": {
          "$ref": "#/$defs/visual"
        },
        "stats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stat"
          }
        },
        "callouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callout"
          }
        },
        "table": {
          "$ref": "#/$defs/table"
        },
        "comparison": {
          "$ref": "#/$defs/comparison"
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "process": {
          "$ref": "#/$defs/process"
        },
        "diagram": {
          "$ref": "#/$defs/diagram"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "stats"
              }
            }
          },
          "then": {
            "required": [
              "stats"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "comparison"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "comparison"
                ]
              },
              {
                "required": [
                  "table"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "diagram"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "diagram"
                ]
              },
              {
                "required": [
                  "process"
                ]
              },
              {
                "required": [
                  "chart"
                ]
              },
              {
                "required": [
                  "visual"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "image"
              }
            }
          },
          "then": {
            "required": [
              "visual"
            ]
          }
        }
      ]
    }
  }
}
